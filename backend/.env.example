# MySQL 数据库配置
MYSQL_HOST=your_mysql_host
MYSQL_USERNAME=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=stock_assistant

# 163 邮箱 SMTP 配置（用于监控触发时发送邮件通知）
# 授权码：登录 163 邮箱 → 设置 → POP3/SMTP/IMAP → 开启 SMTP → 生成授权码
EMAIL_USER=your_163_account@163.com
EMAIL_PASS=your_smtp_authorization_code

# 收件人（默认 ljjnotice@163.com，可通过此变量覆盖）
EMAIL_TO=ljjnotice@163.com
