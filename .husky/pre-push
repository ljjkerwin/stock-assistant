#!/bin/bash

# Exit on any command failure
set -e

echo "🔍 Git pre-push 钩子 (Husky) 已触发..."

# Read pushed refs from stdin
while read local_ref local_sha remote_ref remote_sha
do
  # Determine diff range to find which files changed in this push
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    # New branch being pushed. Compare with the most relevant base branch.
    BASE_BRANCH=""
    for candidate in "origin/develop" "origin/main" "develop" "main"; do
      if git rev-parse --verify "$candidate" >/dev/null 2>&1; then
        BASE_BRANCH="$candidate"
        break
      fi
    done

    if [ -n "$BASE_BRANCH" ]; then
      MB=$(git merge-base "$BASE_BRANCH" "$local_sha" 2>/dev/null || true)
      if [ -n "$MB" ]; then
        CHANGED_FILES=$(git diff --name-only "$MB..$local_sha" 2>/dev/null || true)
      else
        CHANGED_FILES=$(git diff --name-only HEAD~1..HEAD 2>/dev/null || true)
      fi
    else
      CHANGED_FILES=$(git diff --name-only HEAD~1..HEAD 2>/dev/null || true)
    fi
  else
    # Existing branch. Compare remote and local SHA.
    CHANGED_FILES=$(git diff --name-only "$remote_sha..$local_sha" 2>/dev/null || true)
  fi

  # Check if backend files are modified
  BACKEND_CHANGED=false
  for FILE in $CHANGED_FILES; do
    if [[ $FILE == backend/* ]]; then
      BACKEND_CHANGED=true
      break
    fi
  done

  # Run backend tests if backend files have changed
  if [ "$BACKEND_CHANGED" = true ]; then
    echo "==========================================="
    echo "🧪 正在运行后端单元测试 (Unit Tests)..."
    echo "==========================================="
    cd backend
    
    if ! pnpm test; then
      echo "❌ 后端单元测试失败！推送已终止。"
      exit 1
    fi
    
    cd ..
    echo "✅ 后端单元测试通过！"
    echo ""
  else
    echo "ℹ️ 未检测到 backend/ 目录下的代码变更，跳过单元测试。"
  fi
done

exit 0
